# Example environment file.
# Copy to .env locally and fill values there.
# Never commit real secrets.

# Binance API keys are only needed for testtrade/paper/live adapters.
# Backtests should run without live trading keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Optional GitHub token for local tooling only.
GITHUB_TOKEN=

# Optional OpenAI/Codex/API integration if local tools require it.
OPENAI_API_KEY=
